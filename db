# MAIN
# ═══════════════════════════════════════════════════════════════
def main():
    parser = argparse.ArgumentParser(description="Guest House DB initializer")
    parser.add_argument("--drop",   action="store_true", help="Drop all objects before creating")
    parser.add_argument("--seed",   action="store_true", help="Insert seed data after creating tables")
    parser.add_argument("--verify", action="store_true", help="Verify schema only, no changes")
    args = parser.parse_args()

    log.info("Connecting to database...")
    try:
        conn = get_connection()
    except Exception as e:
        log.error(f"Connection failed: {e}")
        sys.exit(1)

    conn.autocommit = False
    cur = conn.cursor()

    try:
        if args.verify:
            verify(cur)
            cur.close()
            conn.close()
            return

        if args.drop:
            log.info("Dropping all objects...")
            cur.execute(DROP_SQL)
            conn.commit()
            log.info("Drop complete.")

        log.info("Creating extensions...")
        cur.execute(EXTENSIONS_SQL)

        log.info("Creating enums...")
        cur.execute(ENUMS_SQL)

        log.info("Creating tables...")
        steps = [
            (USERS_SQL,                "users"),
            (LOCATIONS_SQL,            "locations"),
            (GUEST_HOUSES_SQL,         "guest_houses"),
            (GUEST_HOUSE_MANAGERS_SQL, "guest_house_managers"),
            (ROOMS_SQL,                "rooms"),
            (HOLD_SESSIONS_SQL,        "hold_sessions"),
            (BOOKINGS_SQL,             "bookings"),
            (WAITLIST_SQL,             "waitlist"),
            (NOTIFICATIONS_SQL,        "notifications"),
            (AUDIT_LOGS_SQL,           "audit_logs"),
            (SYSTEM_CONFIG_SQL,        "system_config"),
        ]
        for sql, label in steps:
            run(cur, sql, label)

        log.info("Creating triggers...")
        run(cur, TRIGGERS_SQL,                "updated_at triggers")
        run(cur, ROOM_COUNT_TRIGGER_SQL,      "room count trigger")
        run(cur, AUDIT_IMMUTABLE_TRIGGER_SQL, "audit immutability trigger")
        run(cur, BOOKING_REF_TRIGGER_SQL,     "booking_ref auto-generation")

        log.info("Creating views...")
        run(cur, VIEWS_SQL, "all views")

        if args.seed:
            seed_data(cur)

        conn.commit()
        log.info("─────────────────────────────────────────")
        log.info("Schema initialized successfully.")
        log.info("─────────────────────────────────────────")

        verify(cur)

    except Exception as e:
        conn.rollback()
        log.error(f"Error: {e}")
        cur.close()
        conn.close()
        sys.exit(1)

    cur.close()
    conn.close()


if __name__ == "__main__":
    main()
