EXPECTED_TABLES = [
    "users", "locations", "guest_houses", "guest_house_managers",
    "rooms", "hold_sessions", "bookings", "waitlist",
    "notifications", "audit_logs", "system_config",
]

EXPECTED_VIEWS = [
    "v_room_availability", "v_manager_dashboard",
    "v_occupancy_report", "v_active_holds",
]


def verify(cursor):
    cursor.execute("""
        SELECT tablename FROM pg_tables
        WHERE schemaname = 'public'
        ORDER BY tablename;
    """)
    existing_tables = {r[0] for r in cursor.fetchall()}

    cursor.execute("""
        SELECT viewname FROM pg_views
        WHERE schemaname = 'public'
        ORDER BY viewname;
    """)
    existing_views = {r[0] for r in cursor.fetchall()}

    log.info("─── Table verification ───────────────────")
    all_ok = True
    for t in EXPECTED_TABLES:
        ok = t in existing_tables
        if ok:
            log.info(f"  ✓  {t}")
        else:
            log.error(f"  ✗  {t}  MISSING")
            all_ok = False

    log.info("─── View verification ────────────────────")
    for v in EXPECTED_VIEWS:
        ok = v in existing_views
        if ok:
            log.info(f"  ✓  {v}")
        else:
            log.error(f"  ✗  {v}  MISSING")
            all_ok = False

    if all_ok:
        log.info("All tables and views present.")
    else:
        log.error("Some objects are missing — re-run without --verify to recreate.")
    return all_ok


