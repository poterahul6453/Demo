VIEWS_SQL = """
-- v_room_availability: rooms with their next booking date for the availability page
CREATE OR REPLACE VIEW v_room_availability AS
SELECT
    r.id                    AS room_id,
    r.guest_house_id,
    r.room_number,
    r.floor,
    r.type,
    r.status,
    r.has_ac,
    r.has_wifi,
    r.has_tv,
    r.max_occupancy,
    r.pos_x,
    r.pos_y,
    gh.name                 AS guest_house_name,
    l.name                  AS location_name,
    l.city,
    -- Next confirmed booking start date (for UI display)
    (
        SELECT MIN(b.check_in_date)
        FROM bookings b
        WHERE b.room_id = r.id
          AND b.status IN ('pending', 'confirmed', 'checked_in')
          AND b.check_in_date >= CURRENT_DATE
    )                       AS next_booking_date,
    -- Active hold expiry (if any)
    (
        SELECT h.hold_expiry
        FROM hold_sessions h
        WHERE h.room_id = r.id
          AND h.is_released = FALSE
          AND h.hold_expiry > NOW()
        ORDER BY h.created_at DESC
        LIMIT 1
    )                       AS active_hold_expiry
FROM rooms r
JOIN guest_houses gh ON gh.id = r.guest_house_id
JOIN locations l     ON l.id  = gh.location_id
WHERE r.id IS NOT NULL;


-- v_manager_dashboard: pending bookings routed to the correct manager
CREATE OR REPLACE VIEW v_manager_dashboard AS
SELECT
    b.id                    AS booking_id,
    b.booking_ref,
    b.status                AS booking_status,
    b.check_in_date,
    b.check_out_date,
    b.purpose,
    b.created_at            AS requested_at,
    b.escalated,
    b.escalated_at,
    u.name                  AS employee_name,
    u.email                 AS employee_email,
    u.department,
    r.room_number,
    r.floor,
    r.type                  AS room_type,
    r.status                AS room_status,
    gh.id                   AS guest_house_id,
    gh.name                 AS guest_house_name,
    l.name                  AS location_name,
    ghm.user_id             AS manager_id
FROM bookings b
JOIN rooms r         ON r.id  = b.room_id
JOIN guest_houses gh ON gh.id = r.guest_house_id
JOIN locations l     ON l.id  = gh.location_id
JOIN users u         ON u.id  = b.employee_id
JOIN guest_house_managers ghm
                     ON ghm.guest_house_id = gh.id
                    AND ghm.is_active = TRUE;


-- v_occupancy_report: admin occupancy stats by guest house
CREATE OR REPLACE VIEW v_occupancy_report AS
SELECT
    gh.id                               AS guest_house_id,
    gh.name                             AS guest_house_name,
    l.name                              AS location_name,
    COUNT(r.id)                         AS total_rooms,
    COUNT(r.id) FILTER (WHERE r.status = 'available')           AS available,
    COUNT(r.id) FILTER (WHERE r.status = 'held')                AS held,
    COUNT(r.id) FILTER (WHERE r.status IN ('reserved_pending', 'reserved_confirmed')) AS reserved,
    COUNT(r.id) FILTER (WHERE r.status = 'occupied')            AS occupied,
    COUNT(r.id) FILTER (WHERE r.status = 'cleaning')            AS cleaning,
    COUNT(r.id) FILTER (WHERE r.status = 'maintenance')         AS maintenance,
    ROUND(
        100.0 * COUNT(r.id) FILTER (WHERE r.status = 'occupied') /
        NULLIF(COUNT(r.id), 0), 1
    )                                   AS occupancy_pct
FROM guest_houses gh
JOIN locations l ON l.id = gh.location_id
LEFT JOIN rooms r ON r.guest_house_id = gh.id
WHERE gh.is_active = TRUE
GROUP BY gh.id, gh.name, l.name;


-- v_active_holds: for the hold expiry background job
CREATE OR REPLACE VIEW v_active_holds AS
SELECT
    h.id,
    h.room_id,
    h.employee_id,
    h.hold_expiry,
    h.requested_check_in,
    h.requested_check_out,
    r.guest_house_id,
    r.status AS room_status
FROM hold_sessions h
JOIN rooms r ON r.id = h.room_id
WHERE h.is_released = FALSE
  AND h.hold_expiry <= NOW();
