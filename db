# TRIGGERS: updated_at auto-maintenance
# ═══════════════════════════════════════════════════════════════
TRIGGERS_SQL = """
CREATE OR REPLACE FUNCTION set_updated_at()
RETURNS TRIGGER AS $$
BEGIN
    NEW.updated_at = NOW();
    RETURN NEW;
END;
$$ LANGUAGE plpgsql;

DO $$ DECLARE
    t TEXT;
BEGIN
    FOREACH t IN ARRAY ARRAY[
        'users', 'locations', 'guest_houses', 'rooms', 'bookings'
    ] LOOP
        EXECUTE format(
            'DROP TRIGGER IF EXISTS trg_%1$s_updated_at ON %1$s;
             CREATE TRIGGER trg_%1$s_updated_at
             BEFORE UPDATE ON %1$s
             FOR EACH ROW EXECUTE FUNCTION set_updated_at();',
            t
        );
    END LOOP;
END $$;
"""


# ═══════════════════════════════════════════════════════════════
# TRIGGER: total_rooms counter on guest_houses
# ═══════════════════════════════════════════════════════════════
ROOM_COUNT_TRIGGER_SQL = """
CREATE OR REPLACE FUNCTION sync_guest_house_room_count()
RETURNS TRIGGER AS $$
BEGIN
    IF TG_OP = 'INSERT' THEN
        UPDATE guest_houses SET total_rooms = total_rooms + 1
        WHERE id = NEW.guest_house_id;
    ELSIF TG_OP = 'DELETE' THEN
        UPDATE guest_houses SET total_rooms = total_rooms - 1
        WHERE id = OLD.guest_house_id;
    END IF;
    RETURN NULL;
END;
$$ LANGUAGE plpgsql;

DROP TRIGGER IF EXISTS trg_rooms_count ON rooms;
CREATE TRIGGER trg_rooms_count
AFTER INSERT OR DELETE ON rooms
FOR EACH ROW EXECUTE FUNCTION sync_guest_house_room_count();
"""


# ═══════════════════════════════════════════════════════════════
# TRIGGER: audit_logs is append-only
# Prevent any UPDATE or DELETE on audit_logs.
# ═══════════════════════════════════════════════════════════════
AUDIT_IMMUTABLE_TRIGGER_SQL = """
CREATE OR REPLACE FUNCTION deny_audit_mutation()
RETURNS TRIGGER AS $$
BEGIN
    RAISE EXCEPTION 'audit_logs is immutable — UPDATE and DELETE are not permitted.';
END;
$$ LANGUAGE plpgsql;

DROP TRIGGER IF EXISTS trg_audit_immutable ON audit_logs;
CREATE TRIGGER trg_audit_immutable
BEFORE UPDATE OR DELETE ON audit_logs
FOR EACH ROW EXECUTE FUNCTION deny_audit_mutation();
"""


# ═══════════════════════════════════════════════════════════════
# TRIGGER: booking_ref auto-generation
# Format: GH-YYYY-NNNNN (e.g. GH-2024-00142)
# ═══════════════════════════════════════════════════════════════
BOOKING_REF_TRIGGER_SQL = """
CREATE SEQUENCE IF NOT EXISTS booking_ref_seq START 1 INCREMENT 1;

CREATE OR REPLACE FUNCTION generate_booking_ref()
RETURNS TRIGGER AS $$
BEGIN
    IF NEW.booking_ref IS NULL OR NEW.booking_ref = '' THEN
        NEW.booking_ref := 'GH-' || TO_CHAR(NOW(), 'YYYY') || '-' ||
                           LPAD(nextval('booking_ref_seq')::TEXT, 5, '0');
    END IF;
    RETURN NEW;
END;
$$ LANGUAGE plpgsql;

DROP TRIGGER IF EXISTS trg_booking_ref ON bookings;
CREATE TRIGGER trg_booking_ref
BEFORE INSERT ON bookings
FOR EACH ROW EXECUTE FUNCTION generate_booking_ref();
"""


